diff --git a/Xext/sophia-routed-input/sophia-routed-input.c b/Xext/sophia-routed-input/sophia-routed-input.c
new file mode 100644
index 0000000000..0000000000
--- /dev/null
+++ b/Xext/sophia-routed-input/sophia-routed-input.c
@@ -0,0 +1,243 @@
