 }
 
+static void
+ProcessDeviceEvent(InternalEvent *ev, DeviceIntPtr device)
+{
+    ProcessDeviceEventForWindow(ev, device, NullWindow);
+}
+
+int
+ProcessRoutedPointerEvent(DeviceIntPtr device, WindowPtr routedWin,
+                          InternalEvent *ev)
+{
+    if (!device || !routedWin || !IsPointerDevice(device) ||
+        (!InputDevIsMaster(device) && !InputDevIsFloating(device)))
+        return BadDevice;
+
+    if (!IsPointerEvent(ev))
+        return BadValue;
+
+    ProcessDeviceEventForWindow(ev, device, routedWin);
+    return Success;
+}
