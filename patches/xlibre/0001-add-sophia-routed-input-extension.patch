diff --git a/dix/events.c b/dix/events.c
index 80128fef2..98f0c8599 100644
--- a/dix/events.c
+++ b/dix/events.c
@@ -3151,8 +3151,44 @@ ActivateEnterGrab(DeviceIntPtr dev, WindowPtr old, WindowPtr win)
  *
  * @return TRUE if the sprite has moved or FALSE otherwise.
  */
-Bool
-CheckMotion(DeviceEvent *ev, DeviceIntPtr pDev)
+static Bool
+SetSpriteTraceToWindow(SpritePtr pSprite, WindowPtr pWin)
+{
+    WindowPtr walk;
+    int depth = 0;
+    int i;
+
+    if (!pWin || !pWin->realized)
+        return FALSE;
+
+    for (walk = pWin; walk; walk = walk->parent)
+        depth++;
+
+    if (depth <= 0)
+        return FALSE;
+
+    if (depth > pSprite->spriteTraceSize) {
+        WindowPtr *trace = reallocarray(pSprite->spriteTrace,
+                                        depth, sizeof(*trace));
+        if (!trace)
+            return FALSE;
+
+        pSprite->spriteTrace = trace;
+        pSprite->spriteTraceSize = depth;
+    }
+
+    i = depth - 1;
+    for (walk = pWin; walk; walk = walk->parent)
+        pSprite->spriteTrace[i--] = walk;
+
+    pSprite->spriteTraceGood = depth;
+    pSprite->hot.pScreen = pWin->drawable.pScreen;
+    pSprite->hotPhys.pScreen = pWin->drawable.pScreen;
+    return TRUE;
+}
+
+static Bool
+CheckMotionToWindow(DeviceEvent *ev, DeviceIntPtr pDev, WindowPtr routedWin)
 {
     WindowPtr prevSpriteWin, newSpriteWin;
     SpritePtr pSprite = pDev->spriteInfo->sprite;
@@ -3236,7 +3272,15 @@ CheckMotion(DeviceEvent *ev, DeviceIntPtr pDev)
         ev->root_y = pSprite->hot.y;
     }
 
-    newSpriteWin = XYToWindow(pSprite, pSprite->hot.x, pSprite->hot.y);
+    if (routedWin) {
+        if (!SetSpriteTraceToWindow(pSprite, routedWin))
+            return FALSE;
+
+        newSpriteWin = routedWin;
+    }
+    else {
+        newSpriteWin = XYToWindow(pSprite, pSprite->hot.x, pSprite->hot.y);
+    }
 
     if (newSpriteWin != prevSpriteWin) {
         int sourceid;
@@ -3263,6 +3307,18 @@ CheckMotion(DeviceEvent *ev, DeviceIntPtr pDev)
     return TRUE;
 }
 
+Bool
+CheckMotion(DeviceEvent *ev, DeviceIntPtr pDev)
+{
+    return CheckMotionToWindow(ev, pDev, NullWindow);
+}
+
+Bool
+CheckMotionWithWindow(DeviceEvent *ev, DeviceIntPtr pDev, WindowPtr pWin)
+{
+    return CheckMotionToWindow(ev, pDev, pWin);
+}
