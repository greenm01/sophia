+#include <dix-config.h>
+
+#include <X11/X.h>
+#include <X11/Xmd.h>
+#include <X11/Xproto.h>
+
+#include "dix/dix_priv.h"
+#include "dix/exevents_priv.h"
+#include "dix/input_priv.h"
+#include "dix/request_priv.h"
+#include "include/dixaccess.h"
+#include "include/input.h"
+#include "include/inputstr.h"
+#include "include/windowstr.h"
+#include "miext/extinit_priv.h"
+
+#include "eventstr.h"
+
+#define SOPHIA_ROUTED_INPUT_NAME "SOPHIA-ROUTED-INPUT"
+#define SOPHIA_ROUTED_INPUT_MAJOR_VERSION 0
+#define SOPHIA_ROUTED_INPUT_MINOR_VERSION 1
+
+#define X_SophiaRoutedInputQueryVersion 0
+#define X_SophiaRoutedInputRouteEvent 1
+
+#define SophiaRoutedInputOutcomeAccepted 0
+#define SophiaRoutedInputOutcomeRejectedStaleTarget 1
+#define SophiaRoutedInputOutcomeRejectedDeniedNamespace 2
+#define SophiaRoutedInputOutcomeRejectedActiveGrab 3
+#define SophiaRoutedInputOutcomeRejectedFocusPolicy 4
+#define SophiaRoutedInputOutcomeRejectedUnsupportedEvent 5
+
+#define SophiaRoutedInputEventMotion 1
+#define SophiaRoutedInputEventButton 2
+#define SophiaRoutedInputEventKey 3
+
+typedef struct {
+    CARD8 reqType;
+    CARD8 routedReqType;
+    CARD16 length;
+    CARD16 majorVersion;
+    CARD16 minorVersion;
+} xSophiaRoutedInputQueryVersionReq;
+
+typedef struct {
+    BYTE type;
+    BYTE pad0;
+    CARD16 sequenceNumber;
+    CARD32 length;
+    CARD16 majorVersion;
+    CARD16 minorVersion;
+    CARD32 pad1;
+    CARD32 pad2;
+    CARD32 pad3;
+    CARD32 pad4;
+    CARD32 pad5;
+} xSophiaRoutedInputQueryVersionReply;
+
+typedef struct {
+    CARD8 reqType;
+    CARD8 routedReqType;
+    CARD16 length;
+    CARD32 serial_hi;
+    CARD32 serial_lo;
+    CARD32 target_xid;
+    CARD32 seat;
+    CARD32 device;
+    CARD32 time_msec;
+    INT32 local_x_24_8;
+    INT32 local_y_24_8;
+    CARD16 event_code;
+    CARD16 detail;
+    CARD32 flags;
+} xSophiaRoutedInputRouteEventReq;
+
+typedef struct {
+    BYTE type;
+    BYTE pad0;
+    CARD16 sequenceNumber;
+    CARD32 length;
+    CARD32 serial_hi;
+    CARD32 serial_lo;
+    CARD32 target_xid;
+    CARD16 outcome;
+    CARD16 pad1;
+    CARD32 pad2;
+    CARD32 pad3;
+} xSophiaRoutedInputRouteEventReply;
+
+static int ProcSophiaRoutedInputDispatch(ClientPtr client);
+
+static int
+route_event_type(const xSophiaRoutedInputRouteEventReq *stuff)
+{
+    switch (stuff->event_code) {
+    case SophiaRoutedInputEventMotion:
+        return MotionNotify;
+    case SophiaRoutedInputEventButton:
+        return (stuff->flags & 1) ? ButtonPress : ButtonRelease;
+    default:
+        return 0;
+    }
+}
+
+static int
+ProcSophiaRoutedInputQueryVersion(ClientPtr client)
+{
+    X_REQUEST_HEAD_STRUCT(xSophiaRoutedInputQueryVersionReq);
+    X_REQUEST_FIELD_CARD16(majorVersion);
+    X_REQUEST_FIELD_CARD16(minorVersion);
+
+    xSophiaRoutedInputQueryVersionReply reply = {
+        .majorVersion = SOPHIA_ROUTED_INPUT_MAJOR_VERSION,
+        .minorVersion = SOPHIA_ROUTED_INPUT_MINOR_VERSION,
+    };
+
+    X_REPLY_FIELD_CARD16(majorVersion);
+    X_REPLY_FIELD_CARD16(minorVersion);
+
+    return X_SEND_REPLY_SIMPLE(client, reply);
+}
+
+static int
+send_route_reply(ClientPtr client,
+                 const xSophiaRoutedInputRouteEventReq *stuff,
+                 CARD16 outcome)
+{
+    xSophiaRoutedInputRouteEventReply reply = {
+        .serial_hi = stuff->serial_hi,
+        .serial_lo = stuff->serial_lo,
+        .target_xid = stuff->target_xid,
+        .outcome = outcome,
+    };
+
+    X_REPLY_FIELD_CARD32(serial_hi);
+    X_REPLY_FIELD_CARD32(serial_lo);
+    X_REPLY_FIELD_CARD32(target_xid);
+    X_REPLY_FIELD_CARD16(outcome);
+
+    return X_SEND_REPLY_SIMPLE(client, reply);
+}
+
+static int
+validate_route_event_kind(const xSophiaRoutedInputRouteEventReq *stuff)
+{
+    switch (stuff->event_code) {
+    case SophiaRoutedInputEventMotion:
+        if (stuff->detail != 0)
+            return BadValue;
+        return Success;
+    case SophiaRoutedInputEventButton:
+        if (stuff->detail == 0)
+            return BadValue;
+        return Success;
+    case SophiaRoutedInputEventKey:
+        return BadImplementation;
+    default:
+        return BadValue;
+    }
+}
+
+static int
+ProcSophiaRoutedInputRouteEvent(ClientPtr client)
+{
+    X_REQUEST_HEAD_STRUCT(xSophiaRoutedInputRouteEventReq);
+    X_REQUEST_FIELD_CARD32(serial_hi);
+    X_REQUEST_FIELD_CARD32(serial_lo);
+    X_REQUEST_FIELD_CARD32(target_xid);
+    X_REQUEST_FIELD_CARD32(seat);
+    X_REQUEST_FIELD_CARD32(device);
+    X_REQUEST_FIELD_CARD32(time_msec);
+    X_REQUEST_FIELD_CARD32(local_x_24_8);
+    X_REQUEST_FIELD_CARD32(local_y_24_8);
+    X_REQUEST_FIELD_CARD16(event_code);
+    X_REQUEST_FIELD_CARD16(detail);
+    X_REQUEST_FIELD_CARD32(flags);
+
+    WindowPtr pWin = NULL;
+    DeviceIntPtr dev = NULL;
+    InternalEvent *events = NULL;
+    ValuatorMask *mask = NULL;
+    double local_x;
+    double local_y;
+    double desktop_x;
+    double desktop_y;
+    int button = 0;
+    int type;
+    int nevents;
+    int rc;
+
+    if (stuff->seat == 0 || stuff->device == 0) {
+        client->errorValue = 0;
+        return BadValue;
+    }
+
+    rc = validate_route_event_kind(stuff);
+    if (rc == BadImplementation)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+    if (rc != Success) {
+        client->errorValue = stuff->event_code;
+        return rc;
+    }
+
+    rc = dixLookupWindow(&pWin, stuff->target_xid, client, DixSendAccess);
+    if (rc == BadAccess)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedDeniedNamespace);
+    if (rc != Success)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedStaleTarget);
+
+    if (!pWin->realized)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedStaleTarget);
+
+    rc = dixLookupDevice(&dev, stuff->device, client, DixWriteAccess);
+    if (rc != Success)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+
+    if (!IsPointerDevice(dev) ||
+        (!InputDevIsMaster(dev) && !InputDevIsFloating(dev)) ||
+        !dev->valuator || !dev->button)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+
+    if (dev->deviceGrab.sync.frozen)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedActiveGrab);
+
+    local_x = (double) stuff->local_x_24_8 / 256.0;
+    local_y = (double) stuff->local_y_24_8 / 256.0;
+
+    if (local_x < 0 || local_y < 0 ||
+        local_x >= pWin->drawable.width ||
+        local_y >= pWin->drawable.height)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedStaleTarget);
+
+    type = route_event_type(stuff);
+    if (type == 0)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+
+    if (type == ButtonPress || type == ButtonRelease) {
+        button = stuff->detail;
+        if (button <= 0 || button >= MAX_BUTTONS) {
+            client->errorValue = stuff->detail;
+            return BadValue;
+        }
+    }
+
+    desktop_x = pWin->drawable.pScreen->x + pWin->drawable.x + local_x;
+    desktop_y = pWin->drawable.pScreen->y + pWin->drawable.y + local_y;
+
+    mask = valuator_mask_new(2);
+    events = InitEventList(GetMaximumEventsNum());
+    if (!mask || !events) {
+        valuator_mask_free(&mask);
+        FreeEventList(events, GetMaximumEventsNum());
+        return BadAlloc;
+    }
+
+    valuator_mask_set_double(mask, 0, desktop_x);
+    valuator_mask_set_double(mask, 1, desktop_y);
+
+    nevents = GetPointerEvents(events, dev, type, button,
+                               POINTER_ABSOLUTE | POINTER_DESKTOP | POINTER_NORAW,
+                               mask);
+
+    for (int i = 0; i < nevents; i++) {
+        switch (events[i].any.type) {
+        case ET_Motion:
+        case ET_ButtonPress:
+        case ET_ButtonRelease:
+            if (stuff->time_msec != 0)
+                events[i].device_event.time = stuff->time_msec;
+
+            rc = ProcessRoutedPointerEvent(dev, pWin, &events[i]);
+            if (rc != Success) {
+                valuator_mask_free(&mask);
+                FreeEventList(events, GetMaximumEventsNum());
+                return send_route_reply(client, stuff,
+                                        SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+            }
+            break;
+        default:
+            break;
+        }
+    }
+
+    valuator_mask_free(&mask);
+    FreeEventList(events, GetMaximumEventsNum());
+
+    if (nevents <= 0)
+        return send_route_reply(client, stuff,
+                                SophiaRoutedInputOutcomeRejectedUnsupportedEvent);
+
+    return send_route_reply(client, stuff, SophiaRoutedInputOutcomeAccepted);
+}
+
+static int
+ProcSophiaRoutedInputDispatch(ClientPtr client)
+{
+    REQUEST(xReq);
+
+    switch (stuff->data) {
+    case X_SophiaRoutedInputQueryVersion:
+        return ProcSophiaRoutedInputQueryVersion(client);
+    case X_SophiaRoutedInputRouteEvent:
+        return ProcSophiaRoutedInputRouteEvent(client);
+    default:
+        return BadRequest;
+    }
+}
+
+void
+SophiaRoutedInputExtensionInit(void)
+{
+    if (!AddExtension(SOPHIA_ROUTED_INPUT_NAME, 0, 0,
+                      ProcSophiaRoutedInputDispatch,
+                      ProcSophiaRoutedInputDispatch,
+                      NULL, StandardMinorOpcode))
+        FatalError("SophiaRoutedInputExtensionInit: AddExtension failed.\n");
+}
