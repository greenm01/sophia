 #ifdef XINERAMA
     {PanoramiXExtensionInit, "XINERAMA", &noPanoramiXExtension},
 #endif /* XINERAMA */
diff --git a/miext/extinit_priv.h b/miext/extinit_priv.h
index 0000000000..0000000000 100644
--- a/miext/extinit_priv.h
+++ b/miext/extinit_priv.h
@@ -62,5 +62,6 @@ void dri3_extension_init(void);
 void PseudoramiXExtensionInit(void);
 void present_extension_init(void);
 void NamespaceExtensionInit(void);
+void SophiaRoutedInputExtensionInit(void);
 
 #endif /* _XSERVER_EXTINIT_PRIV_H */
